<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Center - Gerador & Classificador</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <main class="main-container">
    
    <!-- CARD 1: GERADOR DE SENHAS AVANÇADO -->
    <section class="card">
      <h2>🔑 Gerador de Senhas Pro</h2>
      
      <div class="input-display">
        <input type="text" id="campo-senha" readonly placeholder="Sua senha aparecerá aqui">
        <button id="btn-copiar" onclick="copiarSenha()">📋 Copiar</button>
      </div>

      <div class="config-group">
        <label for="txt-tamanho">Tamanho da senha (<span id="valor-tamanho">12</span> caracteres):</label>
        <input type="range" id="txt-tamanho" min="4" max="30" value="12" oninput="atualizarLabelTamanho()">
      </div>

      <fieldset class="checkbox-container">
        <legend>Configurações de Complexidade</legend>
        
        <div class="checkbox-group">
          <input type="checkbox" id="chk-maiusculas" checked>
          <label for="chk-maiusculas">Incluir Letras Maiúsculas</label>
        </div>
        
        <div class="checkbox-group">
          <input type="checkbox" id="chk-minusculas" checked>
          <label for="chk-minusculas">Incluir Letras Minúsculas</label>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="evitar-ambiguos">
          <label for="evitar-ambiguos">Evitar caracteres ambíguos (Ex: o, O, 0, i, 1, l)</label>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="incluir-espacos">
          <label for="incluir-espacos">Incluir espaços em branco</label>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="comecar-letra">
          <label for="comecar-letra">Começar obrigatoriamente com letra</label>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="chk-criptografia">
          <label for="chk-criptografia">Simular Hash Criptográfico (SHA-256)</label>
        </div>
      </fieldset>

      <button class="btn-gerar" onclick="gerarSenha()">Gerar Senha Segura</button>

      <!-- Indicador de Força por Entropia -->
      <div class="container-forca">
        <span id="texto-forca" class="texto-forca">Força da Senha: Aguardando...</span>
        <div class="barra-forca-bg">
          <div id="barra-forca" class="barra-forca-progresso"></div>
        </div>
      </div>
    </section>

    <!-- CARD 2: CLASSIFICADOR DE IDADE -->
    <section class="card">
      <h2>👥 Classificador de Idade</h2>
      <p class="subtitulo">Validação de intervalos numéricos</p>
      
      <div class="input-group">
        <label for="txt-idade">Digite a idade:</label>
        <input type="number" id="txt-idade" min="0" max="120" placeholder="Ex: 15">
      </div>
      
      <button class="btn-gerar" onclick="classificarIdade()">Classificar Idade</button>

      <div class="container-forca">
        <span id="texto-resultado" class="texto-forca">Aguardando idade...</span>
        <div class="barra-forca-bg">
          <div id="barra-classificacao" class="barra-forca-progresso"></div>
        </div>
      </div>
    </section>

  </main>

  <script src="script.js"></script>
</body>
</html>
